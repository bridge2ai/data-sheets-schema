digraph D4DROCrateProfile {
  rankdir=LR;
  splines=true;
  overlap=false;
  ranksep=1.0;
  nodesep=0.4;
  graph [bgcolor=white, pad=0.4];
  node [shape=record, fontname="Helvetica", fontsize=10, style="rounded,filled", fillcolor="#FFFFFF", color="#666666"];
  edge [fontname="Helvetica", fontsize=10, color="#1976D2", fontcolor="#1976D2"];
  "CreativeWork" [label="{ CreativeWork }", fillcolor="#E2F2E3", color="#388E3C", penwidth=1.5];
  "Dataset" [label="{ Dataset | ── schema.org ──\l  + Dataset\l  + name\l  + description\l  + identifier\l  + keywords\l  + inLanguage\l  + license\l  + …+27 more\l── DCAT ──\l  + contentSize\l── FAIRSCAPE EVI ──\l  + evi:md5\l  + evi:sha256\l  + evi:formats\l  + evi:samplingPlan\l── Croissant RAI ──\l  + rai:dataCollection\l  + rai:dataCollectionTimeframe\l  + rai:personalSensitiveInformation\l  + rai:dataSocialImpact\l  + rai:prohibitedUses\l  + rai:ethicalReview\l  + rai:dataUseCases\l  + …+12 more\l── D4D-specific ──\l  + d4d:addressingGaps\l  + d4d:dataAnomalies\l  + d4d:contentWarning\l  + d4d:informedConsent\l  + d4d:humanSubject\l  + d4d:atRiskPopulations\l  + d4d:participantCompensation\l  + …+2 more\l }", fillcolor="#D8EAF7", color="#1976D2", penwidth=2.5, fontname="Helvetica"];
  "DefinedTerm" [label="{ DefinedTerm }", fillcolor="#E2F2E3", color="#388E3C", penwidth=1.5];
  "Grant" [label="{ Grant }", fillcolor="#E2F2E3", color="#388E3C", penwidth=1.5];
  "MediaObject" [label="{ MediaObject | + fileType\l }", fillcolor="#FFEAD4", color="#F57C00", penwidth=2];
  "Organization" [label="{ Organization }", fillcolor="#E2F2E3", color="#388E3C", penwidth=1.5];
  "Person" [label="{ Person }", fillcolor="#E2F2E3", color="#388E3C", penwidth=1.5];
  "ROCrate" [label="{ ROCrate }", fillcolor="#D8EAF7", color="#1976D2", penwidth=2.5, fontname="Helvetica"];

  "Dataset" -> "Organization" [label="publisher"];
  "Dataset" -> "Grant" [label="funder"];
  "Dataset" -> "CreativeWork" [label="citation"];
  "Dataset" -> "Person" [label="author"];
  "Dataset" -> "Person" [label="creator"];
  "Dataset" -> "Person" [label="contributor"];
  "Dataset" -> "DefinedTerm" [label="about"];
  "Dataset" -> "Person" [label="maintainer"];

  edge [arrowhead=empty, style=dashed, color="#1976D2"];
  "Dataset" -> "ROCrate" [label="@type=[Dataset, EVI#ROCrate]\nat @id=./", fontcolor="#1976D2"];
  "Dataset" -> "MediaObject" [label="hasPart"];
}
