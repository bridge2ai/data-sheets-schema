  RICH ==projection==> CORE
  DIST --> D1
  DIST --> D2
  FC --> D3

  classDef d4d fill:#D8EAF7,stroke:#1976D2,stroke-width:2px;
  classDef exch fill:#F3E5F5,stroke:#7B1FA2,stroke-width:2px;
  classDef data fill:#F5F5F5,stroke:#787878,stroke-width:2px;
