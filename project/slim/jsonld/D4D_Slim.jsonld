      ],
      "range": "uri",
      "@type": "SlotDefinition"
    },
    {
      "name": "license",
      "definition_uri": "https://w3id.org/bridge2ai/data-sheets-schema/slim#license",
      "description": "License under which the resource is distributed",
      "from_schema": "https://w3id.org/bridge2ai/data-sheets-schema/slim",
      "mappings": [
        "http://purl.org/dc/terms/license"
      ],
      "slot_uri": "http://purl.org/dc/terms/license",
      "owner": "Dataset",
      "domain_of": [
        "Information",
        "Software",
        "Dataset"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "license_and_use_terms",
      "definition_uri": "https://w3id.org/bridge2ai/data-sheets-schema/slim#license_and_use_terms",
      "description": "Detailed licensing and terms of use information, including any fees. Simplified to string in D4D Slim.",
      "from_schema": "https://w3id.org/bridge2ai/data-sheets-schema/slim",
      "slot_uri": "https://w3id.org/bridge2ai/data-sheets-schema/slim#license_and_use_terms",
      "owner": "Dataset",
      "domain_of": [
        "Dataset"
      ],
      "range": "string",
      "multivalued": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "version",
      "definition_uri": "https://w3id.org/bridge2ai/data-sheets-schema/slim#version",
      "description": "Version identifier for the resource",
      "from_schema": "https://w3id.org/bridge2ai/data-sheets-schema/slim",
      "mappings": [
        "http://schema.org/version"
      ],
      "slot_uri": "http://schema.org/version",
      "owner": "Dataset",
      "domain_of": [
        "Information",
        "Software",
        "Dataset"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "status",
      "definition_uri": "https://w3id.org/bridge2ai/data-sheets-schema/slim#status",
      "description": "Status of the resource (e.g., draft, published, deprecated)",
      "from_schema": "https://w3id.org/bridge2ai/data-sheets-schema/slim",
      "slot_uri": "https://w3id.org/bridge2ai/data-sheets-schema/slim#status",
      "owner": "Dataset",
      "domain_of": [
        "Information",
        "Dataset"
      ],
      "range": "uri",
